{
  "name": "delivery-management-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node -r ./vite-crypto-polyfill.cjs ./node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "tsc && node -r ./vite-crypto-polyfill.cjs ./node_modules/vite/bin/vite.js build",
    "preview": "node -r ./vite-crypto-polyfill.cjs ./node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.7.9",
    "vite": "^6.0.1",
    "typescript": "^5.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.0.2",
    "lucide-react": "^0.468.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8"
  }
}
